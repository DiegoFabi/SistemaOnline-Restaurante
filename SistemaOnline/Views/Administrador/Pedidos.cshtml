@model List<SistemaOnline.Models.Pedido>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Monitor de Pedidos";
    ViewBag.Active = "pedidos";
}

<div class="mb-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Monitor de Pedidos</h2>
    <p class="text-on-surface-variant">Pedidos activos en el restaurante.</p>
</div>

<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg">
        <table class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Mesa</th>
                    <th class="pb-md font-bold">Cliente</th>
                    <th class="pb-md font-bold">Mesero</th>
                    <th class="pb-md font-bold">Total</th>
                    <th class="pb-md font-bold">Estado</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var p in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">#@p.ID_Pedido</td>
                        <td class="py-md">@(p.Mesa_Restaurante != null ? "Mesa " + p.Mesa_Restaurante.Numero_Mesa : "-")</td>
                        <td class="py-md">@(p.Cliente != null ? p.Cliente.Nombre + " " + p.Cliente.Apellidos : "-")</td>
                        <td class="py-md">@(p.Empleado != null ? p.Empleado.Nombre + " " + p.Empleado.Apellidos : "-")</td>
                        <td class="py-md font-bold">@p.Total.ToString("C2")</td>
                        <td class="py-md">
                            <span class="px-sm py-xs bg-tertiary-container text-on-tertiary-container rounded-full text-label-md">@p.Estado_Pedido</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
