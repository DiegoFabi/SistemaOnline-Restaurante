@model List<SistemaOnline.Models.Reservacion>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Reservaciones";
    ViewBag.Active = "reservaciones";
    ViewData["Controlador"] = "Administrador";
    ViewData["AccionLista"] = "Reservaciones";
}

<div class="mb-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Reservaciones</h2>
    <p class="text-on-surface-variant">Listado completo de reservaciones.</p>
</div>

<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg">
        <table class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">Fecha/Hora</th>
                    <th class="pb-md font-bold">Cliente</th>
                    <th class="pb-md font-bold">Mesa</th>
                    <th class="pb-md font-bold">Personas</th>
                    <th class="pb-md font-bold">Ocasión</th>
                    <th class="pb-md font-bold">Estado</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var r in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@r.Fecha_Hora.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="py-md">@(r.Cliente != null ? r.Cliente.Nombre + " " + r.Cliente.Apellidos : "-")</td>
                        <td class="py-md">@(r.Mesa_Restaurante != null ? "Mesa " + r.Mesa_Restaurante.Numero_Mesa : "-")</td>
                        <td class="py-md font-mono-data">@r.Numero_Personas</td>
                        <td class="py-md">@r.Ocasion_Especial</td>
                        <td class="py-md">
                            <span class="px-sm py-xs bg-secondary-container text-on-secondary-container rounded-full text-label-md">@r.Estado_Reservacion</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_Pagination" />
