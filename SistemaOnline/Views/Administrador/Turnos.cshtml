@model List<SistemaOnline.Models.Turno>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Gestión de Turnos";
    ViewBag.Active = "turnos";
}

<div class="mb-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Turnos y Personal</h2>
    <p class="text-on-surface-variant">Personal asignado en tiempo real según la configuración de turnos.</p>
</div>

<div class="grid grid-cols-1 gap-lg">
    @foreach (var t in Model)
    {
        <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
            <div class="p-lg border-b border-outline-variant/10 bg-surface-container-low flex justify-between items-center">
                <div>
                    <h3 class="font-title-md text-title-md text-on-surface uppercase tracking-wider font-bold">@t.Nombre_Turno</h3>
                    <p class="text-label-md text-primary font-bold">
                        @t.Hora_Inicio.ToString(@"hh\:mm") - @t.Hora_Fin.ToString(@"hh\:mm") | @t.Dias_Semana
                    </p>
                </div>
                <div class="text-right">
                    <span class="block text-display-lg font-bold text-primary">@t.Empleado_Turnos.Count()</span>
                    <span class="text-label-md text-on-surface-variant">Empleados Asignados</span>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="text-label-md text-on-surface-variant bg-surface-container-highest/30">
                        <tr>
                            <th class="px-lg py-sm">DNI</th>
                            <th class="px-lg py-sm">Nombre Completo</th>
                            <th class="px-lg py-sm">Cargo</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/20">
                        @if (t.Empleado_Turnos.Any())
                        {
                            @foreach (var et in t.Empleado_Turnos)
                            {
                                <tr class="hover:bg-primary-fixed/10 transition-colors">
                                    <td class="px-lg py-md font-mono-data text-on-surface-variant">@et.Empleado.DNI</td>
                                    <td class="px-lg py-md font-body-lg text-on-surface font-semibold">@et.Empleado.Nombre @et.Empleado.Apellidos</td>
                                    <td class="px-lg py-md text-body-md text-on-surface-variant">@et.Empleado.Cargo</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="px-lg py-xl text-center text-outline">
                                    <div class="flex flex-col items-center gap-sm">
                                        <span class="material-symbols-outlined text-outline">info</span>
                                        No hay empleados registrados en este horario.
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>