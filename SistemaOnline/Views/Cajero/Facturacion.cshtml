@model List<SistemaOnline.Models.Pedido>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Facturación";
    ViewBag.Active = "facturacion";
    ViewData["Controlador"] = "Cajero";
    ViewData["AccionLista"] = "Facturacion";
}

<div class="mb-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Facturación</h2>
    <p class="text-on-surface-variant">Listado de pedidos para facturación.</p>
</div>

<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg">
        <table class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Fecha</th>
                    <th class="pb-md font-bold">Mesa</th>
                    <th class="pb-md font-bold">Subtotal</th>
                    <th class="pb-md font-bold">Total</th>
                    <th class="pb-md font-bold">Estado</th>
                    <th class="pb-md font-bold"></th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var p in Model)
                {
                    var cobrable = p.Estado_Pedido == "Pendiente" || p.Estado_Pedido == "Servido";
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">#@p.ID_Pedido</td>
                        <td class="py-md">@p.Fecha.ToString("dd/MM/yyyy")</td>
                        <td class="py-md">@(p.Mesa_Restaurante != null ? "Mesa " + p.Mesa_Restaurante.Numero_Mesa : "-")</td>
                        <td class="py-md font-mono-data">@p.SubTotal.ToString("C2")</td>
                        <td class="py-md font-bold">@p.Total.ToString("C2")</td>
                        <td class="py-md">
                            <span class="px-sm py-xs bg-primary-container text-on-primary-container rounded-full text-label-md">@p.Estado_Pedido</span>
                        </td>
                        <td class="py-md text-right">
                            @if (cobrable)
                            {
                                <a asp-controller="Comprobante_Pago" asp-action="Nuevo" asp-route-idPedido="@p.ID_Pedido" class="inline-flex items-center gap-xs h-9 px-sm bg-primary hover:bg-on-primary-fixed-variant text-on-primary font-label-md text-label-md rounded-lg transition-all">
                                    <span class="material-symbols-outlined text-[16px]">point_of_sale</span> Cobrar
                                </a>
                            }
                            else
                            {
                                <button type="button" disabled class="inline-flex items-center gap-xs h-9 px-sm bg-surface-container-high text-on-surface-variant font-label-md text-label-md rounded-lg cursor-not-allowed">
                                    <span class="material-symbols-outlined text-[16px]">point_of_sale</span> Cobrar
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_Pagination" />