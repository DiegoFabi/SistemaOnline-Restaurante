@model List<SistemaOnline.Models.Pago>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Pagos";
    ViewBag.Active = "pagos";
    ViewData["Controlador"] = "Cajero";
    ViewData["AccionLista"] = "Pagos";
}

<div class="mb-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Historial de Pagos</h2>
    <p class="text-on-surface-variant">Todos los pagos procesados.</p>
</div>

<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg">
        <table class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID Pago</th>
                    <th class="pb-md font-bold">Pedido</th>
                    <th class="pb-md font-bold">Fecha</th>
                    <th class="pb-md font-bold">Método</th>
                    <th class="pb-md font-bold">Monto</th>
                    <th class="pb-md font-bold">Estado</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var pg in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">#@pg.ID_Pago</td>
                        <td class="py-md font-mono-data">#@pg.ID_Pedido</td>
                        <td class="py-md">@pg.Fecha_Hora_Pago.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="py-md">@pg.Metodo_Pago</td>
                        <td class="py-md font-bold">@pg.Monto.ToString("C2")</td>
                        <td class="py-md">
                            <span class="px-sm py-xs bg-secondary-container text-on-secondary-container rounded-full text-label-md">@pg.Estado</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_Pagination" />
