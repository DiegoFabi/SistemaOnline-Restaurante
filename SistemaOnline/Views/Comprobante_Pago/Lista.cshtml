@model List<SistemaOnline.ViewModels.Comprobante_PagoVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Comprobantes de Pago";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Lista de Comprobantes de Pago";
    ViewData["Descripcion"] = "Administra los comprobantes de pago emitidos.";
    ViewData["Controlador"] = "Comprobante_Pago";
    ViewData["NuevoTexto"] = "Nuevo Comprobante";
    ViewData["BuscadorPlaceholder"] = "Buscar por tipo, número, serie, estado...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Tipo</th>
                    <th class="pb-md font-bold">Número</th>
                    <th class="pb-md font-bold">Serie</th>
                    <th class="pb-md font-bold">Fecha de Emisión</th>
                    <th class="pb-md font-bold">Monto Total</th>
                    <th class="pb-md font-bold">Estado</th>
                    <th class="pb-md font-bold col-ellipsis">Pedido</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Comprobante</td>
                        <td class="py-md font-bold">@item.Tipo_Comprobante</td>
                        <td class="py-md font-mono-data">@item.Numero_Comprobante</td>
                        <td class="py-md font-mono-data">@item.Serie</td>
                        <td class="py-md font-mono-data">@item.Fecha_Emision.ToString("dd/MM/yyyy")</td>
                        <td class="py-md font-mono-data">@item.Monto_Total</td>
                        <td class="py-md">@item.Estado_Comprobante</td>
                        <td class="py-md col-ellipsis" title="@item.PedidoInfo">@item.PedidoInfo</td>
                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Comprobante_Pago" asp-action="Editar" asp-route-id="@item.ID_Comprobante" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Comprobante_Pago" asp-action="Eliminar" asp-route-id="@item.ID_Comprobante"  class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_Pagination" />