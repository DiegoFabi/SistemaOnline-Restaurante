@model List<SistemaOnline.ViewModels.ContratoVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Contratos";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Lista de Contratos";
    ViewData["Descripcion"] = "Administra los contratos registrados.";
    ViewData["Controlador"] = "Contrato";
    ViewData["NuevoTexto"] = "Nuevo Contrato";
    ViewData["BuscadorPlaceholder"] = "Buscar por tipo, empleado, proveedor...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Fecha Inicio</th>
                    <th class="pb-md font-bold">Fecha Fin</th>
                    <th class="pb-md font-bold">Tipo Contrato</th>
                    <th class="pb-md font-bold">Salario</th>
                    <th class="pb-md font-bold">Empleado</th>
                    <th class="pb-md font-bold">Proveedor</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Contrato</td>
                        <td class="py-md font-mono-data">@item.Fecha_Inicio.ToString("dd/MM/yyyy")</td>
                        <td class="py-md font-mono-data">@item.Fecha_Fin.ToString("dd/MM/yyyy")</td>
                        <td class="py-md font-bold">@item.Tipo_Contrato</td>
                        <td class="py-md font-mono-data">@item.Salario</td>
                        <td class="py-md">@item.EmpleadoNombre</td>
                        <td class="py-md">@item.ProveedorNombre</td>
                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Contrato" asp-action="Editar" asp-route-id="@item.ID_Contrato" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Contrato" asp-action="Eliminar" asp-route-id="@item.ID_Contrato" onclick="return confirm('¿Estás seguro de eliminar este registro?');" class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
