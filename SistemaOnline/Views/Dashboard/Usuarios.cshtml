@model List<SistemaOnline.Models.Usuario>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Usuarios y Roles";
    ViewBag.Active = "usuarios";
}

<div class="mb-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Gestión de Usuarios y Roles</h2>
    <p class="text-on-surface-variant">Administración de cuentas y permisos del sistema.</p>
</div>

<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg">
        <table class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Usuario</th>
                    <th class="pb-md font-bold">Email</th>
                    <th class="pb-md font-bold">Rol</th>
                    <th class="pb-md font-bold">Estado</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var u in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">#@u.ID_Usuario</td>
                        <td class="py-md font-bold">@u.Nombre_Usuario</td>
                        <td class="py-md">@u.Email</td>
                        <td class="py-md">
                            <span class="px-sm py-xs bg-primary-container text-on-primary-container rounded-full text-label-md">@u.Rol?.Nombre_Rol</span>
                        </td>
                        <td class="py-md">
                            @if (u.Estado)
                            {
                                <span class="px-sm py-xs bg-secondary-container text-on-secondary-container rounded-full text-label-md">Activo</span>
                            }
                            else
                            {
                                <span class="px-sm py-xs bg-error-container text-on-error-container rounded-full text-label-md">Inactivo</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
