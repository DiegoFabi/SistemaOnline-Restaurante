@model List<SistemaOnline.ViewModels.EmpleadoVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Empleados";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Lista de Empleados";
    ViewData["Descripcion"] = "Administra los empleados registrados.";
    ViewData["Controlador"] = "Empleado";
    ViewData["NuevoTexto"] = "Nuevo Empleado";
    ViewData["BuscadorPlaceholder"] = "Buscar por nombre, cargo, DNI...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold col-ellipsis">Nombre</th>
                    <th class="pb-md font-bold col-ellipsis">Apellidos</th>
                    <th class="pb-md font-bold col-ellipsis">Dirección</th>
                    <th class="pb-md font-bold">Cargo</th>
                    <th class="pb-md font-bold">Teléfono</th>
                    <th class="pb-md font-bold">Estado</th>
                    <th class="pb-md font-bold">DNI</th>
                    <th class="pb-md font-bold">Usuario</th>
                    <th class="pb-md font-bold">Turno</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Empleado</td>
                        <td class="py-md font-bold col-ellipsis" title="@item.Nombre">@item.Nombre</td>
                        <td class="py-md col-ellipsis" title="@item.Apellidos">@item.Apellidos</td>
                        <td class="py-md col-ellipsis" title="@item.Direccion">@item.Direccion</td>
                        <td class="py-md">@item.Cargo</td>
                        <td class="py-md">@item.Telefono</td>
                        <td class="py-md">@item.Estado</td>
                        <td class="py-md font-mono-data">@item.DNI</td>
                        <td class="py-md">@item.UsuarioNombre</td>

                        <td class="py-md">
                            @(ViewBag.TurnosEmpleados.ContainsKey(item.ID_Empleado) ? ViewBag.TurnosEmpleados[item.ID_Empleado] : "Sin asignar")
                        </td>

                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Empleado" asp-action="Editar" asp-route-id="@item.ID_Empleado" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Empleado" asp-action="Eliminar" asp-route-id="@item.ID_Empleado" onclick="return confirm('¿Estás seguro de eliminar este registro?');" class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_Pagination" />