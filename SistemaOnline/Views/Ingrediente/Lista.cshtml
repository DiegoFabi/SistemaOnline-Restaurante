@model List<SistemaOnline.ViewModels.IngredienteVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Ingredientes";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Lista de Ingredientes";
    ViewData["Descripcion"] = "Administra los ingredientes registrados.";
    ViewData["Controlador"] = "Ingrediente";
    ViewData["NuevoTexto"] = "Nuevo Ingrediente";
    ViewData["BuscadorPlaceholder"] = "Buscar por nombre, unidad, categoría...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Nombre</th>
                    <th class="pb-md font-bold">Unidad de Medida</th>
                    <th class="pb-md font-bold">Descripción</th>
                    <th class="pb-md font-bold">Costo Unitario</th>
                    <th class="pb-md font-bold">Activo</th>
                    <th class="pb-md font-bold">Categoría</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Ingrediente</td>
                        <td class="py-md font-bold">@item.Nombre_Ingrediente</td>
                        <td class="py-md">@item.Unidad_Medida</td>
                        <td class="py-md">@item.Descripcion</td>
                        <td class="py-md font-mono-data">@item.Costo_Unitario</td>
                        <td class="py-md">@(item.Estado ? "Sí" : "No")</td>
                        <td class="py-md">@item.CategoriaNombre</td>
                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Ingrediente" asp-action="Editar" asp-route-id="@item.ID_Ingrediente" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Ingrediente" asp-action="Eliminar" asp-route-id="@item.ID_Ingrediente" onclick="return confirm('¿Estás seguro de eliminar este registro?');" class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
