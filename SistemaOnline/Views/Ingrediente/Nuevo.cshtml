@model SistemaOnline.ViewModels.IngredienteVM
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Nuevo Ingrediente";
    ViewBag.Active = "negocio";
    string Cls(string campo) => !ViewData.ModelState.ContainsKey(campo) || ViewData.ModelState[campo].Errors.Count == 0
        ? "w-full h-11 px-md bg-surface-container-low border border-transparent rounded-lg focus:ring-2 focus:ring-primary/20 transition-all font-body-md text-body-md text-on-surface"
        : "w-full h-11 px-md bg-surface-container-low border border-error rounded-lg focus:ring-2 focus:ring-error/20 transition-all font-body-md text-body-md text-on-surface";
}
<div class="max-w-2xl mx-auto">
    <div class="mb-lg">
        <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Nuevo Ingrediente</h2>
        <p class="text-on-surface-variant">Registra un nuevo ingrediente.</p>
    </div>
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg">
        <form asp-controller="Ingrediente" asp-action="Nuevo" method="post" autocomplete="off" class="space-y-md">
            <div asp-validation-summary="ModelOnly" class="text-error text-body-md"></div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Nombre_Ingrediente">Nombre del Ingrediente</label>
                <input class="@Cls("Nombre_Ingrediente")" type="text" required asp-for="Nombre_Ingrediente" />
                <span asp-validation-for="Nombre_Ingrediente" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Unidad_Medida">Unidad de Medida</label>
                <input class="@Cls("Unidad_Medida")" type="text" required asp-for="Unidad_Medida" />
                <span asp-validation-for="Unidad_Medida" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Descripcion">Descripción</label>
                <input class="@Cls("Descripcion")" type="text" required asp-for="Descripcion" />
                <span asp-validation-for="Descripcion" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Costo_Unitario">Costo Unitario</label>
                <input class="@Cls("Costo_Unitario")" type="number" step="0.01" required asp-for="Costo_Unitario" />
                <span asp-validation-for="Costo_Unitario" class="text-error text-label-md"></span>
            </div>
            <div class="flex items-center gap-sm">
                <input type="checkbox" asp-for="Estado" id="Estado" class="h-5 w-5 rounded border-outline-variant text-primary focus:ring-2 focus:ring-primary/20" />
                <label class="font-label-md text-label-md text-on-surface-variant" for="Estado">Activo</label>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="ID_Cat_Ingrediente">Categoría</label>
                <select class="@Cls("ID_Cat_Ingrediente")" asp-for="ID_Cat_Ingrediente" asp-items="Model.CategoriasDisponibles">
                    <option value="">-- Seleccione --</option>
                </select>
                <span asp-validation-for="ID_Cat_Ingrediente" class="text-error text-label-md"></span>
            </div>
            <div class="flex items-center gap-sm pt-md">
                <button type="submit" class="inline-flex items-center gap-sm h-11 px-md bg-primary hover:bg-on-primary-fixed-variant text-on-primary font-title-md text-title-md rounded-lg shadow-md shadow-primary/20 transition-all active:scale-[0.98]">
                    <span class="material-symbols-outlined">save</span> Guardar
                </button>
                <a asp-controller="Ingrediente" asp-action="Lista" class="inline-flex items-center gap-sm h-11 px-md bg-surface-container-high text-on-surface font-title-md text-title-md rounded-lg transition-all hover:bg-surface-container-highest">
                    <span class="material-symbols-outlined">arrow_back</span> Volver
                </a>
            </div>
        </form>
    </div>
</div>
