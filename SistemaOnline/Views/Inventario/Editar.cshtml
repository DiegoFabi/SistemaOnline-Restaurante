@model SistemaOnline.ViewModels.InventarioVM
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Editar Inventario";
    ViewBag.Active = "negocio";
    string Cls(string campo) => !ViewData.ModelState.ContainsKey(campo) || ViewData.ModelState[campo].Errors.Count == 0
        ? "w-full h-11 px-md bg-surface-container-low border border-transparent rounded-lg focus:ring-2 focus:ring-primary/20 transition-all font-body-md text-body-md text-on-surface"
        : "w-full h-11 px-md bg-surface-container-low border border-error rounded-lg focus:ring-2 focus:ring-error/20 transition-all font-body-md text-body-md text-on-surface";
}
<div class="max-w-2xl mx-auto">
    <div class="mb-lg">
        <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Editar Inventario</h2>
        <p class="text-on-surface-variant">Actualiza la información del inventario.</p>
    </div>
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg">
        <form asp-controller="Inventario" asp-action="Editar" method="post" autocomplete="off" class="space-y-md">
            <div asp-validation-summary="ModelOnly" class="text-error text-body-md"></div>
            <input type="hidden" asp-for="ID_Inventario" />
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Cantidad_Stock">Cantidad en Stock</label>
                <input class="@Cls("Cantidad_Stock")" type="number" step="0.01" required asp-for="Cantidad_Stock" />
                <span asp-validation-for="Cantidad_Stock" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Fecha_Ultima_Reposicion">Fecha de Última Reposición</label>
                <input class="@Cls("Fecha_Ultima_Reposicion")" type="date" required asp-for="Fecha_Ultima_Reposicion" />
                <span asp-validation-for="Fecha_Ultima_Reposicion" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Stock_Minimo">Stock Mínimo</label>
                <input class="@Cls("Stock_Minimo")" type="number" step="0.01" required asp-for="Stock_Minimo" />
                <span asp-validation-for="Stock_Minimo" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Stock_Maximo">Stock Máximo</label>
                <input class="@Cls("Stock_Maximo")" type="number" step="0.01" required asp-for="Stock_Maximo" />
                <span asp-validation-for="Stock_Maximo" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="ID_Ingrediente">Ingrediente</label>
                <select class="@Cls("ID_Ingrediente")" asp-for="ID_Ingrediente" asp-items="Model.IngredientesDisponibles">
                    <option value="">-- Seleccione --</option>
                </select>
                <span asp-validation-for="ID_Ingrediente" class="text-error text-label-md"></span>
            </div>
            <div class="flex items-center gap-sm pt-md">
                <button type="submit" class="inline-flex items-center gap-sm h-11 px-md bg-primary hover:bg-on-primary-fixed-variant text-on-primary font-title-md text-title-md rounded-lg shadow-md shadow-primary/20 transition-all active:scale-[0.98]">
                    <span class="material-symbols-outlined">save</span> Guardar
                </button>
                <a asp-controller="Inventario" asp-action="Lista" class="inline-flex items-center gap-sm h-11 px-md bg-surface-container-high text-on-surface font-title-md text-title-md rounded-lg transition-all hover:bg-surface-container-highest">
                    <span class="material-symbols-outlined">arrow_back</span> Volver
                </a>
            </div>
        </form>
    </div>
</div>
