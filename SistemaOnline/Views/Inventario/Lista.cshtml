@model List<SistemaOnline.ViewModels.InventarioVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Inventarios";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Lista de Inventarios";
    ViewData["Descripcion"] = "Administra el inventario de ingredientes.";
    ViewData["Controlador"] = "Inventario";
    ViewData["NuevoTexto"] = "Nuevo Inventario";
    ViewData["BuscadorPlaceholder"] = "Buscar por ingrediente...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Cantidad en Stock</th>
                    <th class="pb-md font-bold">Última Reposición</th>
                    <th class="pb-md font-bold">Stock Mínimo</th>
                    <th class="pb-md font-bold">Stock Máximo</th>
                    <th class="pb-md font-bold col-ellipsis">Ingrediente</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Inventario</td>
                        <td class="py-md font-mono-data">@item.Cantidad_Stock</td>
                        <td class="py-md font-mono-data">@item.Fecha_Ultima_Reposicion.ToString("dd/MM/yyyy")</td>
                        <td class="py-md font-mono-data">@item.Stock_Minimo</td>
                        <td class="py-md font-mono-data">@item.Stock_Maximo</td>
                        <td class="py-md font-bold col-ellipsis" title="@item.IngredienteNombre">@item.IngredienteNombre</td>
                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Inventario" asp-action="Editar" asp-route-id="@item.ID_Inventario" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Inventario" asp-action="Eliminar" asp-route-id="@item.ID_Inventario" onclick="return confirm('¿Estás seguro de eliminar este registro?');" class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_Pagination" />