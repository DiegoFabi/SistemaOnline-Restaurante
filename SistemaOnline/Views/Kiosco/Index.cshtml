@model List<SistemaOnline.Models.Producto>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Rancho Sagrado - Kiosco</title>
    <partial name="_DesignTokensHead" />
</head>
<body class="bg-[#f8f9fa] text-on-surface font-body-md min-h-screen">
    <header class="bg-[#212529] text-white px-8 py-6 flex items-center justify-between shadow-md">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-[36px]">restaurant_menu</span>
            <h1 class="text-3xl font-extrabold tracking-tight">Rancho Sagrado</h1>
        </div>
        <nav class="flex gap-4 text-lg font-bold">
            <a class="px-4 py-2 rounded-full bg-white/20" asp-controller="Kiosco" asp-action="Index">Carta</a>
            <a class="px-4 py-2 rounded-full hover:bg-white/20" asp-controller="Kiosco" asp-action="Reservaciones">Reservaciones</a>
            <a class="px-4 py-2 rounded-full hover:bg-white/20" asp-controller="Login" asp-action="Login">Iniciar Sesión</a>
        </nav>
    </header>

    <main class="px-8 py-10 max-w-6xl mx-auto">
        <h2 class="text-4xl font-extrabold mb-2">Nuestra Carta</h2>
        <p class="text-lg text-[#5b4040] mb-8">Selecciona tus platos favoritos y realiza tu pedido.</p>

        <div id="grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var p in Model)
            {
                <div class="bg-white rounded-2xl shadow-lg p-6 flex flex-col gap-3 border border-[#e3bebd]">
                    <span class="text-xs font-bold uppercase tracking-widest text-[#b9172f]">@p.Producto_Categoria.Nombre_Categoria</span>
                    <h3 class="text-2xl font-bold">@p.Nombre_Plato</h3>
                    <p class="text-[#5b4040] flex-1">@p.Descripcion</p>
                    <div class="flex items-center justify-between mt-2">
                        <span class="text-2xl font-extrabold text-[#b9172f]">@p.Precio.ToString("C2")</span>
                        <button type="button" data-nombre="@p.Nombre_Plato" data-precio="@p.Precio"
                                class="btn-agregar bg-[#b9172f] text-white rounded-full px-5 py-2 font-bold hover:bg-[#92001f] transition-colors">
                            Agregar
                        </button>
                    </div>
                </div>
            }
        </div>
    </main>

    <div id="carritoFlotante" class="fixed bottom-6 right-6 bg-[#b9172f] text-white rounded-full shadow-xl px-6 py-4 font-bold flex items-center gap-2 cursor-pointer">
        <span class="material-symbols-outlined">shopping_cart</span>
        <span id="carritoCount">0</span> ítems
    </div>

    <div id="modalPedido" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
        <div class="bg-white rounded-2xl p-8 max-w-md w-full">
            <h3 class="text-2xl font-bold mb-4">Tu pedido</h3>
            <ul id="listaPedido" class="space-y-2 mb-4 max-h-60 overflow-y-auto"></ul>
            <p class="font-bold text-lg mb-4">Total: <span id="totalPedido">S/ 0.00</span></p>
            <div class="flex gap-3">
                <button onclick="cerrarModal()" class="flex-1 px-4 py-2 rounded-lg border border-[#8f6f6f] font-bold">Cerrar</button>
                <button onclick="confirmarPedido()" class="flex-1 px-4 py-2 rounded-lg bg-[#b9172f] text-white font-bold">Realizar Pedido</button>
            </div>
        </div>
    </div>

    <script>
        const carrito = [];
        const carritoFlotante = document.getElementById('carritoFlotante');
        const modalPedido = document.getElementById('modalPedido');

        document.querySelectorAll('.btn-agregar').forEach(function (btn) {
            btn.addEventListener('click', function () {
                carrito.push({ nombre: btn.dataset.nombre, precio: parseFloat(btn.dataset.precio) });
                document.getElementById('carritoCount').textContent = carrito.length;
            });
        });

        carritoFlotante.addEventListener('click', function () {
            const lista = document.getElementById('listaPedido');
            lista.innerHTML = carrito.map(function (item) {
                return '<li class="flex justify-between"><span>' + item.nombre + '</span><span>S/ ' + item.precio.toFixed(2) + '</span></li>';
            }).join('');
            const total = carrito.reduce(function (acc, item) { return acc + item.precio; }, 0);
            document.getElementById('totalPedido').textContent = 'S/ ' + total.toFixed(2);
            modalPedido.classList.remove('hidden');
            modalPedido.classList.add('flex');
        });

        function cerrarModal() {
            modalPedido.classList.add('hidden');
            modalPedido.classList.remove('flex');
        }

        function confirmarPedido() {
            alert('Pedido registrado. Un mesero confirmará tu solicitud en breve.');
            carrito.length = 0;
            document.getElementById('carritoCount').textContent = '0';
            cerrarModal();
        }
    </script>
</body>
</html>