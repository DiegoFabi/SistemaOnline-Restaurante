@model SistemaOnline.ViewModels.Mesa_RestauranteVM
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Nueva Mesa";
    ViewBag.Active = "negocio";
    string Cls(string campo) => !ViewData.ModelState.ContainsKey(campo) || ViewData.ModelState[campo].Errors.Count == 0
        ? "w-full h-11 px-md bg-surface-container-low border border-transparent rounded-lg focus:ring-2 focus:ring-primary/20 transition-all font-body-md text-body-md text-on-surface"
        : "w-full h-11 px-md bg-surface-container-low border border-error rounded-lg focus:ring-2 focus:ring-error/20 transition-all font-body-md text-body-md text-on-surface";
}
<div class="max-w-2xl mx-auto">
    <div class="mb-lg">
        <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Nueva Mesa</h2>
        <p class="text-on-surface-variant">Registra una nueva mesa del restaurante.</p>
    </div>
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg">
        <form asp-controller="Mesa_Restaurante" asp-action="Nuevo" method="post" autocomplete="off" class="space-y-md">
            <div asp-validation-summary="ModelOnly" class="text-error text-body-md"></div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Numero_Mesa">Número de Mesa</label>
                <input class="@Cls("Numero_Mesa")" type="number" required asp-for="Numero_Mesa" />
                <span asp-validation-for="Numero_Mesa" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Capacidad">Capacidad (N° de personas)</label>
                <input class="@Cls("Capacidad")" type="number" required asp-for="Capacidad" />
                <span asp-validation-for="Capacidad" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Ubicacion">Ubicación</label>
                <input class="@Cls("Ubicacion")" type="text" required asp-for="Ubicacion" />
                <span asp-validation-for="Ubicacion" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Estado">Estado de la Mesa</label>
                <select class="@Cls("Estado")" required asp-for="Estado">
                    <option value="Disponible" selected>Disponible</option>
                    <option value="Ocupada">Ocupada</option>
                    <option value="Reservada">Reservada</option>
                </select>
                <span asp-validation-for="Estado" class="text-error text-label-md"></span>
            </div>
            <div class="flex items-center gap-sm pt-md">
                <button type="submit" class="inline-flex items-center gap-sm h-11 px-md bg-primary hover:bg-on-primary-fixed-variant text-on-primary font-title-md text-title-md rounded-lg shadow-md shadow-primary/20 transition-all active:scale-[0.98]">
                    <span class="material-symbols-outlined">save</span> Guardar
                </button>
                <a asp-controller="Mesa_Restaurante" asp-action="Lista" class="inline-flex items-center gap-sm h-11 px-md bg-surface-container-high text-on-surface font-title-md text-title-md rounded-lg transition-all hover:bg-surface-container-highest">
                    <span class="material-symbols-outlined">arrow_back</span> Volver
                </a>
            </div>
        </form>
    </div>
</div>