@model SistemaOnline.ViewModels.PagoVM
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Editar Pago";
    ViewBag.Active = "negocio";
    string Cls(string campo) => !ViewData.ModelState.ContainsKey(campo) || ViewData.ModelState[campo].Errors.Count == 0
        ? "w-full h-11 px-md bg-surface-container-low border border-transparent rounded-lg focus:ring-2 focus:ring-primary/20 transition-all font-body-md text-body-md text-on-surface"
        : "w-full h-11 px-md bg-surface-container-low border border-error rounded-lg focus:ring-2 focus:ring-error/20 transition-all font-body-md text-body-md text-on-surface";
}
<div class="max-w-2xl mx-auto">
    <div class="mb-lg">
        <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Editar Pago</h2>
        <p class="text-on-surface-variant">Actualiza la información del pago.</p>
    </div>
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg">
        <form asp-controller="Pago" asp-action="Editar" method="post" autocomplete="off" class="space-y-md">
            <div asp-validation-summary="ModelOnly" class="text-error text-body-md"></div>
            <input type="hidden" asp-for="ID_Pago" />
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Fecha_Hora_Pago">Fecha y Hora de Pago</label>
                <input class="@Cls("Fecha_Hora_Pago")" type="datetime-local" required asp-for="Fecha_Hora_Pago" />
                <span asp-validation-for="Fecha_Hora_Pago" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Monto">Monto</label>
                <input class="@Cls("Monto")" type="number" step="0.01" required asp-for="Monto" />
                <span asp-validation-for="Monto" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Metodo_Pago">Método de Pago</label>
                <input class="@Cls("Metodo_Pago")" type="text" required asp-for="Metodo_Pago" />
                <span asp-validation-for="Metodo_Pago" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Detalles_Tarjeta">Detalles de Tarjeta</label>
                <input class="@Cls("Detalles_Tarjeta")" type="text" asp-for="Detalles_Tarjeta" />
                <span asp-validation-for="Detalles_Tarjeta" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Estado">Estado del Pago</label>
                <select class="@Cls("Estado")" required asp-for="Estado">
                    <option value="Pendiente">Pendiente</option>
                    <option value="Pagado">Pagado</option>
                    <option value="Rechazado">Rechazado</option>
                </select>
                <span asp-validation-for="Estado" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="ID_Pedido">Pedido</label>
                <select class="@Cls("ID_Pedido")" asp-for="ID_Pedido" asp-items="Model.PedidosDisponibles">
                    <option value="" disabled selected hidden>-- Seleccione --</option>
                </select>
                <span asp-validation-for="ID_Pedido" class="text-error text-label-md"></span>
            </div>
            <div class="flex items-center gap-sm pt-md">
                <button type="submit" class="inline-flex items-center gap-sm h-11 px-md bg-primary hover:bg-on-primary-fixed-variant text-on-primary font-title-md text-title-md rounded-lg shadow-md shadow-primary/20 transition-all active:scale-[0.98]">
                    <span class="material-symbols-outlined">save</span> Guardar
                </button>
                <a asp-controller="Pago" asp-action="Lista" class="inline-flex items-center gap-sm h-11 px-md bg-surface-container-high text-on-surface font-title-md text-title-md rounded-lg transition-all hover:bg-surface-container-highest">
                    <span class="material-symbols-outlined">arrow_back</span> Volver
                </a>
            </div>
        </form>
    </div>
</div>