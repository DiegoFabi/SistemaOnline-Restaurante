@model List<SistemaOnline.ViewModels.PagoVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Pagos";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Lista de Pagos";
    ViewData["Descripcion"] = "Administra los pagos registrados.";
    ViewData["Controlador"] = "Pago";
    ViewData["NuevoTexto"] = "Nuevo Pago";
    ViewData["BuscadorPlaceholder"] = "Buscar por método, estado, pedido...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Fecha y Hora</th>
                    <th class="pb-md font-bold">Monto</th>
                    <th class="pb-md font-bold">Método de Pago</th>
                    <th class="pb-md font-bold col-ellipsis">Detalles de Tarjeta</th>
                    <th class="pb-md font-bold">Estado</th>
                    <th class="pb-md font-bold col-ellipsis">Pedido</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Pago</td>
                        <td class="py-md font-mono-data">@item.Fecha_Hora_Pago.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="py-md font-mono-data">@item.Monto</td>
                        <td class="py-md font-bold">@item.Metodo_Pago</td>
                        <td class="py-md col-ellipsis" title="@item.Detalles_Tarjeta">@item.Detalles_Tarjeta</td>
                        <td class="py-md">@item.Estado</td>
                        <td class="py-md col-ellipsis" title="@item.PedidoInfo">@item.PedidoInfo</td>
                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Pago" asp-action="Editar" asp-route-id="@item.ID_Pago" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Pago" asp-action="Eliminar" asp-route-id="@item.ID_Pago" onclick="return confirm('¿Estás seguro de eliminar este registro?');" class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_Pagination" />