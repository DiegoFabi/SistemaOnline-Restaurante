@model SistemaOnline.ViewModels.ProductoVM
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Editar Producto";
    ViewBag.Active = "negocio";
    string Cls(string campo) => !ViewData.ModelState.ContainsKey(campo) || ViewData.ModelState[campo].Errors.Count == 0
        ? "w-full h-11 px-md bg-surface-container-low border border-transparent rounded-lg focus:ring-2 focus:ring-primary/20 transition-all font-body-md text-body-md text-on-surface"
        : "w-full h-11 px-md bg-surface-container-low border border-error rounded-lg focus:ring-2 focus:ring-error/20 transition-all font-body-md text-body-md text-on-surface";
}
<div class="max-w-2xl mx-auto">
    <div class="mb-lg">
        <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Editar Producto</h2>
        <p class="text-on-surface-variant">Modifica los datos del producto.</p>
    </div>
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg">
        <form asp-controller="Producto" asp-action="Editar" method="post" autocomplete="off" class="space-y-md">
            <div asp-validation-summary="ModelOnly" class="text-error text-body-md"></div>
            <input type="hidden" asp-for="ID_Producto" />
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Nombre_Plato">Nombre del Plato</label>
                <input class="@Cls("Nombre_Plato")" type="text" required asp-for="Nombre_Plato" />
                <span asp-validation-for="Nombre_Plato" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Descripcion">Descripción</label>
                <input class="@Cls("Descripcion")" type="text" required asp-for="Descripcion" />
                <span asp-validation-for="Descripcion" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Tiempo_Preparacion">Tiempo de Preparación (minutos)</label>
                <input class="@Cls("Tiempo_Preparacion")" type="number" step="0.1" required asp-for="Tiempo_Preparacion" />
                <span asp-validation-for="Tiempo_Preparacion" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Precio">Precio</label>
                <input class="@Cls("Precio")" type="number" step="0.01" required asp-for="Precio" />
                <span asp-validation-for="Precio" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Disponibilidad">Disponible</label>
                <input class="h-5 w-5 rounded border-outline-variant text-primary focus:ring-primary/20" asp-for="Disponibilidad" type="checkbox" />
                <span asp-validation-for="Disponibilidad" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Categoria">Categoría (texto)</label>
                <input class="@Cls("Categoria")" type="text" required asp-for="Categoria" />
                <span asp-validation-for="Categoria" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="ID_Categoria">Categoría (relación)</label>
                <select class="@Cls("ID_Categoria")" asp-for="ID_Categoria" asp-items="Model.CategoriasDisponibles">
                    <option value="">-- Seleccione --</option>
                </select>
                <span asp-validation-for="ID_Categoria" class="text-error text-label-md"></span>
            </div>
            <div class="flex items-center gap-sm pt-md">
                <button type="submit" class="inline-flex items-center gap-sm h-11 px-md bg-primary hover:bg-on-primary-fixed-variant text-on-primary font-title-md text-title-md rounded-lg shadow-md shadow-primary/20 transition-all active:scale-[0.98]">
                    <span class="material-symbols-outlined">save</span> Guardar
                </button>
                <a asp-controller="Producto" asp-action="Lista" class="inline-flex items-center gap-sm h-11 px-md bg-surface-container-high text-on-surface font-title-md text-title-md rounded-lg transition-all hover:bg-surface-container-highest">
                    <span class="material-symbols-outlined">arrow_back</span> Volver
                </a>
            </div>
        </form>
    </div>
</div>
