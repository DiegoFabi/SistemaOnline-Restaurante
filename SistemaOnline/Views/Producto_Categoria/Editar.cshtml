@model SistemaOnline.ViewModels.Producto_CategoriaVM
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Editar Categoría";
    ViewBag.Active = "negocio";
    string Cls(string campo) => !ViewData.ModelState.ContainsKey(campo) || ViewData.ModelState[campo].Errors.Count == 0
        ? "w-full h-11 px-md bg-surface-container-low border border-transparent rounded-lg focus:ring-2 focus:ring-primary/20 transition-all font-body-md text-body-md text-on-surface"
        : "w-full h-11 px-md bg-surface-container-low border border-error rounded-lg focus:ring-2 focus:ring-error/20 transition-all font-body-md text-body-md text-on-surface";
}
<div class="max-w-2xl mx-auto">
    <div class="mb-lg">
        <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Editar Categoría de Producto</h2>
        <p class="text-on-surface-variant">Actualiza los datos de la categoría.</p>
    </div>
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg">
        <form asp-controller="Producto_Categoria" asp-action="Editar" method="post" autocomplete="off" class="space-y-md">
            <div asp-validation-summary="ModelOnly" class="text-error text-body-md"></div>
            <input type="hidden" asp-for="ID_Categoria" />
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Nombre_Categoria">Nombre de la Categoría</label>
                <input class="@Cls("Nombre_Categoria")" type="text" required asp-for="Nombre_Categoria" />
                <span asp-validation-for="Nombre_Categoria" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Descripcion">Descripción</label>
                <textarea class="@Cls("Descripcion") h-24 py-sm resize-none" required asp-for="Descripcion"></textarea>
                <span asp-validation-for="Descripcion" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="ID_Carta">Carta</label>
                <select class="@Cls("ID_Carta")" asp-for="ID_Carta" asp-items="Model.CartasDisponibles" id="ID_Carta">
                    <option value="" disabled selected hidden>-- Seleccione --</option>
                </select>
                <span asp-validation-for="ID_Carta" class="text-error text-label-md"></span>
            </div>
            <div class="flex items-center gap-sm pt-md">
                <button type="submit" class="inline-flex items-center gap-sm h-11 px-md bg-primary hover:bg-on-primary-fixed-variant text-on-primary font-title-md text-title-md rounded-lg shadow-md shadow-primary/20 transition-all active:scale-[0.98]">
                    <span class="material-symbols-outlined">save</span> Guardar
                </button>
                <a asp-controller="Producto_Categoria" asp-action="Lista" class="inline-flex items-center gap-sm h-11 px-md bg-surface-container-high text-on-surface font-title-md text-title-md rounded-lg transition-all hover:bg-surface-container-highest">
                    <span class="material-symbols-outlined">arrow_back</span> Volver
                </a>
            </div>
        </form>
    </div>
</div>