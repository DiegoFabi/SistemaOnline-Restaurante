@model List<SistemaOnline.ViewModels.Producto_CategoriaVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Categorías de Producto";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Categorías de Producto";
    ViewData["Descripcion"] = "Administra las categorías de productos del menú.";
    ViewData["Controlador"] = "Producto_Categoria";
    ViewData["NuevoTexto"] = "Nueva Categoría";
    ViewData["BuscadorPlaceholder"] = "Buscar por nombre, descripción o carta...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold col-ellipsis">Nombre</th>
                    <th class="pb-md font-bold col-ellipsis">Descripción</th>
                    <th class="pb-md font-bold col-ellipsis">Carta</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Categoria</td>
                        <td class="py-md font-bold col-ellipsis" title="@item.Nombre_Categoria">@item.Nombre_Categoria</td>
                        <td class="py-md col-ellipsis" title="@item.Descripcion">@item.Descripcion</td>
                        <td class="py-md col-ellipsis" title="@item.CartaNombre">@item.CartaNombre</td>
                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Producto_Categoria" asp-action="Editar" asp-route-id="@item.ID_Categoria" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Producto_Categoria" asp-action="Eliminar" asp-route-id="@item.ID_Categoria" onclick="return confirm('¿Estás seguro de eliminar este registro?');" class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_Pagination" />