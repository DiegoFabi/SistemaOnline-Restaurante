@model List<SistemaOnline.ViewModels.ProveedorVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Proveedores";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Lista de Proveedores";
    ViewData["Descripcion"] = "Administra los proveedores registrados.";
    ViewData["Controlador"] = "Proveedor";
    ViewData["NuevoTexto"] = "Nuevo Proveedor";
    ViewData["BuscadorPlaceholder"] = "Buscar por nombre, RUC, email...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Nombre Empresa</th>
                    <th class="pb-md font-bold">RUC</th>
                    <th class="pb-md font-bold">Email de Contacto</th>
                    <th class="pb-md font-bold">Teléfono</th>
                    <th class="pb-md font-bold">Dirección</th>
                    <th class="pb-md font-bold">Tipo de Suministro</th>
                    <th class="pb-md font-bold">Estado</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Proveedor</td>
                        <td class="py-md font-bold">@item.Nombre_Empresa</td>
                        <td class="py-md font-mono-data">@item.RUC</td>
                        <td class="py-md">@item.Email_Contacto</td>
                        <td class="py-md">@item.Telefono</td>
                        <td class="py-md">@item.Direccion</td>
                        <td class="py-md">@item.Tipo_Suministro</td>
                        <td class="py-md">@item.Estado</td>
                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Proveedor" asp-action="Editar" asp-route-id="@item.ID_Proveedor" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Proveedor" asp-action="Eliminar" asp-route-id="@item.ID_Proveedor" onclick="return confirm('¿Estás seguro de eliminar este registro?');" class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
