@model List<SistemaOnline.ViewModels.ReservacionVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Reservaciones";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Lista de Reservaciones";
    ViewData["Descripcion"] = "Administra las reservaciones del restaurante.";
    ViewData["Controlador"] = "Reservacion";
    ViewData["NuevoTexto"] = "Nueva Reservación";
    ViewData["BuscadorPlaceholder"] = "Buscar por cliente, mesa, estado...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Fecha y Hora</th>
                    <th class="pb-md font-bold">N° Personas</th>
                    <th class="pb-md font-bold col-ellipsis">Ocasión Especial</th>
                    <th class="pb-md font-bold">Estado</th>
                    <th class="pb-md font-bold col-ellipsis">Notas</th>
                    <th class="pb-md font-bold col-ellipsis">Cliente</th>
                    <th class="pb-md font-bold">Mesa</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Reservacion</td>
                        <td class="py-md font-mono-data">@item.Fecha_Hora.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="py-md font-mono-data">@item.Numero_Personas</td>
                        <td class="py-md col-ellipsis" title="@item.Ocasion_Especial">@item.Ocasion_Especial</td>
                        <td class="py-md">@item.Estado_Reservacion</td>
                        <td class="py-md col-ellipsis" title="@item.Notas">@item.Notas</td>
                        <td class="py-md font-bold col-ellipsis" title="@item.ClienteNombre">@item.ClienteNombre</td>
                        <td class="py-md">@item.MesaNumero</td>
                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Reservacion" asp-action="Editar" asp-route-id="@item.ID_Reservacion" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Reservacion" asp-action="Eliminar" asp-route-id="@item.ID_Reservacion" onclick="return confirm('¿Estás seguro de eliminar este registro?');" class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_Pagination" />