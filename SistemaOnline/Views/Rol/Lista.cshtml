@model List<SistemaOnline.ViewModels.RolVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Roles";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Lista de Roles";
    ViewData["Descripcion"] = "Administra los roles del sistema.";
    ViewData["Controlador"] = "Rol";
    ViewData["NuevoTexto"] = "Nuevo Rol";
    ViewData["BuscadorPlaceholder"] = "Buscar por nombre...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold">Nombre del Rol</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Rol</td>
                        <td class="py-md font-bold">@item.Nombre_Rol</td>
                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Rol" asp-action="Editar" asp-route-id="@item.ID_Rol" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Rol" asp-action="Eliminar" asp-route-id="@item.ID_Rol" onclick="return confirm('¿Estás seguro de eliminar este registro?');" class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
