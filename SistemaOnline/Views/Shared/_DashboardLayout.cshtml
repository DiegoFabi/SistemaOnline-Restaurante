<!DOCTYPE html>
<html class="light" lang="es">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Rancho Sagrado</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary-container": "#ff6b35",
                        "surface-container-low": "#fff1ed",
                        "on-error": "#ffffff",
                        "on-tertiary": "#ffffff",
                        "on-background": "#261814",
                        "primary-fixed-dim": "#ffb59d",
                        "on-tertiary-container": "#003744",
                        "on-primary": "#ffffff",
                        "error": "#ba1a1a",
                        "on-primary-container": "#5f1900",
                        "error-container": "#ffdad6",
                        "surface-container-highest": "#f7ddd5",
                        "on-primary-fixed": "#390c00",
                        "surface-variant": "#f7ddd5",
                        "primary": "#ab3500",
                        "surface-bright": "#fff8f6",
                        "on-tertiary-fixed-variant": "#004e60",
                        "inverse-on-surface": "#ffede8",
                        "surface-dim": "#eed5cd",
                        "surface": "#fff8f6",
                        "surface-container": "#ffe9e3",
                        "on-surface-variant": "#594139",
                        "surface-container-lowest": "#ffffff",
                        "secondary": "#006a62",
                        "on-secondary": "#ffffff",
                        "on-secondary-fixed-variant": "#005049",
                        "on-secondary-fixed": "#00201d",
                        "secondary-fixed": "#70f8e8",
                        "inverse-primary": "#ffb59d",
                        "on-error-container": "#93000a",
                        "on-tertiary-fixed": "#001f28",
                        "primary-fixed": "#ffdbd0",
                        "inverse-surface": "#3c2d28",
                        "tertiary-fixed": "#b5ebff",
                        "on-secondary-container": "#007168",
                        "background": "#fff8f6",
                        "tertiary-container": "#00a7cb",
                        "on-primary-fixed-variant": "#832600",
                        "on-surface": "#261814",
                        "surface-tint": "#ab3500",
                        "surface-container-high": "#fde3db",
                        "secondary-container": "#70f8e8",
                        "outline-variant": "#e1bfb5",
                        "tertiary-fixed-dim": "#59d5fb",
                        "tertiary": "#00677e",
                        "outline": "#8d7168",
                        "secondary-fixed-dim": "#4fdbcc"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "xs": "4px",
                        "base": "4px",
                        "sm": "8px",
                        "gutter": "16px",
                        "xl": "40px",
                        "md": "16px",
                        "lg": "24px",
                        "container-margin": "24px"
                    },
                    "fontFamily": {
                        "body-md": ["Inter"],
                        "body-lg": ["Inter"],
                        "label-md": ["Inter"],
                        "headline-lg-mobile": ["Inter"],
                        "display-lg": ["Inter"],
                        "title-md": ["Inter"],
                        "headline-lg": ["Inter"],
                        "mono-data": ["JetBrains Mono"]
                    },
                    "fontSize": {
                        "body-md": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "body-lg": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "label-md": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "600" }],
                        "headline-lg-mobile": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "display-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "title-md": ["18px", { "lineHeight": "24px", "fontWeight": "600" }],
                        "headline-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "mono-data": ["14px", { "lineHeight": "20px", "fontWeight": "500" }]
                    }
                },
            },
        }
    </script>
    <style>
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #e1bfb5;
            border-radius: 10px;
        }
        @@keyframes pulse-soft {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }
        .animate-pulse-soft {
            animation: pulse-soft 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md selection:bg-primary-fixed selection:text-on-primary-fixed">
    <partial name="_Sidebar" />
    <main class="pl-64 flex flex-col min-h-screen">
        <header class="fixed top-0 right-0 left-64 h-16 flex items-center justify-between px-6 z-30 bg-surface shadow-sm">
            <div class="flex items-center gap-md flex-1">
                <h2 class="font-title-md text-title-md text-on-surface">@ViewData["Title"]</h2>
            </div>
            <div class="flex items-center gap-lg">
                <div class="flex items-center gap-sm pl-md border-l border-outline-variant">
                    <div class="text-right hidden lg:block">
                        <p class="text-body-md font-bold text-on-surface">@User.Identity?.Name</p>
                        <p class="text-label-md text-on-surface-variant leading-none">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</p>
                    </div>
                    <div class="w-10 h-10 rounded-full border-2 border-primary-fixed shadow-sm bg-primary-container text-on-primary flex items-center justify-center font-bold">
                        @((User.Identity?.Name ?? "?").Substring(0, 1).ToUpper())
                    </div>
                </div>
            </div>
        </header>
        <section class="mt-16 p-lg flex-1 overflow-y-auto custom-scrollbar bg-slate-50">
            @RenderBody()
        </section>
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
