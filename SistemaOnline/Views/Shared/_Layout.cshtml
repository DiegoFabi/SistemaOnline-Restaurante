<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.userway.org/widget.js" data-account="ho4Dn9vmSX"></script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SistemaOnline</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bento.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SistemaOnline.styles.css" asp-append-version="true" />
    <style>
        body {
        background-color: #f8f9fa;
        font-family: 'Work Sans', sans-serif;
        }

        .navbar.bg-white {
        background-color: #212529 !important;
        border-bottom: 2px solid #b9172f !important;
        }

        .navbar .navbar-brand,
        .navbar .nav-link {
        color: #e1e3e4 !important;
        }

        .navbar .nav-link:hover {
        color: #ffc107 !important;
        }

        .btn-primary {
        background-color: #b9172f !important;
        border-color: #b9172f !important;
        }

        .btn-primary:hover {
        background-color: #92001f !important;
        border-color: #92001f !important;
        }

        footer.footer {
        background-color: #f8f9fa;
        border-top: 2px solid #dee2e6 !important;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">SistemaOnline</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link text-dark dropdown-toggle" href="#" id="navModulos" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Modulos
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navModulos">
                                <li><a class="dropdown-item" asp-controller="Rol" asp-action="Lista">Roles</a></li>
                                <li><a class="dropdown-item" asp-controller="Usuario" asp-action="Lista">Usuarios</a></li>
                                <li><a class="dropdown-item" asp-controller="Empleado" asp-action="Lista">Empleados</a></li>
                                <li><a class="dropdown-item" asp-controller="Proveedor" asp-action="Lista">Proveedores</a></li>
                                <li><a class="dropdown-item" asp-controller="Contrato" asp-action="Lista">Contratos</a></li>
                                <li><a class="dropdown-item" asp-controller="Turno" asp-action="Lista">Turnos</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-controller="Carta" asp-action="Lista">Cartas</a></li>
                                <li><a class="dropdown-item" asp-controller="Producto_Categoria" asp-action="Lista">Categorias de Productos</a></li>
                                <li><a class="dropdown-item" asp-controller="Producto" asp-action="Lista">Productos</a></li>
                                <li><a class="dropdown-item" asp-controller="Categoria_Ingrediente" asp-action="Lista">Categorias de Ingredientes</a></li>
                                <li><a class="dropdown-item" asp-controller="Ingrediente" asp-action="Lista">Ingredientes</a></li>
                                <li><a class="dropdown-item" asp-controller="Inventario" asp-action="Lista">Inventario</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-controller="Mesa_Restaurante" asp-action="Lista">Mesas</a></li>
                                <li><a class="dropdown-item" asp-controller="Cliente" asp-action="Lista">Clientes</a></li>
                                <li><a class="dropdown-item" asp-controller="Pedido" asp-action="Lista">Pedidos</a></li>
                                <li><a class="dropdown-item" asp-controller="Pago" asp-action="Lista">Pagos</a></li>
                                <li><a class="dropdown-item" asp-controller="Comprobante_Pago" asp-action="Lista">Comprobantes de Pago</a></li>
                                <li><a class="dropdown-item" asp-controller="Reservacion" asp-action="Lista">Reservaciones</a></li>
                                <li><a class="dropdown-item" asp-controller="Promocion" asp-action="Lista">Promociones</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Negocio" asp-action="Gestion">Administrar Negocio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Dashboard" asp-action="Index">Volver al Panel</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - SistemaOnline - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>