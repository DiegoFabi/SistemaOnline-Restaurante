@model List<SistemaOnline.ViewModels.TurnoVM>
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Turnos";
    ViewBag.Active = "negocio";
    ViewData["Titulo"] = "Lista de Turnos";
    ViewData["Descripcion"] = "Administra los turnos del restaurante.";
    ViewData["Controlador"] = "Turno";
    ViewData["NuevoTexto"] = "Nuevo Turno";
    ViewData["BuscadorPlaceholder"] = "Buscar por nombre, días...";
}
<partial name="_CRUDListLayout" />
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 overflow-hidden">
    <div class="p-lg overflow-x-auto">
        <table id="tablaPrincipal" class="w-full text-left">
            <thead class="text-label-md text-on-surface-variant uppercase tracking-wider">
                <tr>
                    <th class="pb-md font-bold">ID</th>
                    <th class="pb-md font-bold col-ellipsis">Nombre</th>
                    <th class="pb-md font-bold">Hora Inicio</th>
                    <th class="pb-md font-bold">Hora Fin</th>
                    <th class="pb-md font-bold">Días de la Semana</th>
                    <th class="pb-md font-bold">Acciones</th>
                </tr>
            </thead>
            <tbody class="text-body-md">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors border-b border-outline-variant/10">
                        <td class="py-md font-mono-data">@item.ID_Turno</td>
                        <td class="py-md font-bold col-ellipsis" title="@item.Nombre_Turno">@item.Nombre_Turno</td>
                        <td class="py-md font-mono-data">@item.Hora_Inicio</td>
                        <td class="py-md font-mono-data">@item.Hora_Fin</td>
                        <td class="py-md">@item.Dias_Semana</td>
                        <td class="py-md">
                            <div class="flex items-center gap-md">
                                <a asp-controller="Turno" asp-action="Editar" asp-route-id="@item.ID_Turno" class="inline-flex items-center gap-xs text-tertiary hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">edit</span> Editar
                                </a>
                                <a asp-controller="Turno" asp-action="Eliminar" asp-route-id="@item.ID_Turno"  class="inline-flex items-center gap-xs text-error hover:underline">
                                    <span class="material-symbols-outlined text-[18px]">delete</span> Eliminar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<partial name="_Pagination" />