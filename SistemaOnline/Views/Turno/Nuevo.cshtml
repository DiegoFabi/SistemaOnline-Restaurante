@model SistemaOnline.ViewModels.TurnoVM
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Nuevo Turno";
    ViewBag.Active = "negocio";
    string Cls(string campo) => !ViewData.ModelState.ContainsKey(campo) || ViewData.ModelState[campo].Errors.Count == 0
        ? "w-full h-11 px-md bg-surface-container-low border border-transparent rounded-lg focus:ring-2 focus:ring-primary/20 transition-all font-body-md text-body-md text-on-surface"
        : "w-full h-11 px-md bg-surface-container-low border border-error rounded-lg focus:ring-2 focus:ring-error/20 transition-all font-body-md text-body-md text-on-surface";
}
<div class="max-w-2xl mx-auto">
    <div class="mb-lg">
        <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Nuevo Turno</h2>
        <p class="text-on-surface-variant">Registra un nuevo turno.</p>
    </div>
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg">
        <form asp-controller="Turno" asp-action="Nuevo" method="post" autocomplete="off" class="space-y-md">
            <div asp-validation-summary="ModelOnly" class="text-error text-body-md"></div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Nombre_Turno">Nombre del Turno</label>
                <input class="@Cls("Nombre_Turno")" type="text" required asp-for="Nombre_Turno" />
                <span asp-validation-for="Nombre_Turno" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Hora_Inicio">Hora Inicio</label>
                <input class="@Cls("Hora_Inicio")" type="time" required asp-for="Hora_Inicio" />
                <span asp-validation-for="Hora_Inicio" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Hora_Fin">Hora Fin</label>
                <input class="@Cls("Hora_Fin")" type="time" required asp-for="Hora_Fin" />
                <span asp-validation-for="Hora_Fin" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Dias_Semana">Días de la Semana</label>
                <select class="@Cls("Dias_Semana")" required asp-for="Dias_Semana">
                    <option value="" disabled selected hidden>-- Seleccione --</option>
                    <option value="Lunes-Viernes">Lunes-Viernes</option>
                    <option value="Lunes-Sábado">Lunes-Sábado</option>
                    <option value="Sábado-Domingo">Sábado-Domingo</option>
                    <option value="Todos los días">Todos los días</option>
                </select>
                <span asp-validation-for="Dias_Semana" class="text-error text-label-md"></span>
            </div>
            <div class="flex items-center gap-sm pt-md">
                <button type="submit" class="inline-flex items-center gap-sm h-11 px-md bg-primary hover:bg-on-primary-fixed-variant text-on-primary font-title-md text-title-md rounded-lg shadow-md shadow-primary/20 transition-all active:scale-[0.98]">
                    <span class="material-symbols-outlined">save</span> Guardar
                </button>
                <a asp-controller="Turno" asp-action="Lista" class="inline-flex items-center gap-sm h-11 px-md bg-surface-container-high text-on-surface font-title-md text-title-md rounded-lg transition-all hover:bg-surface-container-highest">
                    <span class="material-symbols-outlined">arrow_back</span> Volver
                </a>
            </div>
        </form>
    </div>
</div>