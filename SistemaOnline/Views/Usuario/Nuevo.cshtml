@model SistemaOnline.ViewModels.UsuarioVM
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Nuevo Usuario";
    ViewBag.Active = "negocio";
    string Cls(string campo) => !ViewData.ModelState.ContainsKey(campo) || ViewData.ModelState[campo].Errors.Count == 0
        ? "w-full h-11 px-md bg-surface-container-low border border-transparent rounded-lg focus:ring-2 focus:ring-primary/20 transition-all font-body-md text-body-md text-on-surface"
        : "w-full h-11 px-md bg-surface-container-low border border-error rounded-lg focus:ring-2 focus:ring-error/20 transition-all font-body-md text-body-md text-on-surface";
}
<div class="max-w-2xl mx-auto">
    <div class="mb-lg">
        <h2 class="font-headline-lg text-headline-lg text-on-surface font-extrabold tracking-tight">Nuevo Usuario</h2>
        <p class="text-on-surface-variant">Registra un nuevo usuario.</p>
    </div>
    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/20 p-lg">
        <form asp-controller="Usuario" asp-action="Nuevo" method="post" autocomplete="off" class="space-y-md">
            <div asp-validation-summary="ModelOnly" class="text-error text-body-md"></div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Nombre_Usuario">Nombre Usuario</label>
                <input class="@Cls("Nombre_Usuario")" type="text" required asp-for="Nombre_Usuario" />
                <span asp-validation-for="Nombre_Usuario" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Email">Email</label>
                <input class="@Cls("Email")" type="email" required asp-for="Email" />
                <span asp-validation-for="Email" class="text-error text-label-md"></span>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="Password">Password</label>
                <input class="@Cls("Password")" type="password" required asp-for="Password" />
                <span asp-validation-for="Password" class="text-error text-label-md"></span>
            </div>
            <div class="flex items-center gap-sm">
                <input class="h-5 w-5 rounded border border-outline-variant text-primary focus:ring-2 focus:ring-primary/20" asp-for="Estado" type="checkbox" id="chkEstado" />
                <label class="font-label-md text-label-md text-on-surface-variant" for="chkEstado">Activo</label>
            </div>
            <div>
                <label class="font-label-md text-label-md text-on-surface-variant block mb-1" for="ID_Rol">Rol</label>
                <select class="@Cls("ID_Rol")" asp-for="ID_Rol" asp-items="Model.RolesDisponibles">
                    <option value="" disabled selected hidden>-- Seleccione --</option>
                </select>
                <span asp-validation-for="ID_Rol" class="text-error text-label-md"></span>
            </div>
            <div class="flex items-center gap-sm pt-md">
                <button type="submit" class="inline-flex items-center gap-sm h-11 px-md bg-primary hover:bg-on-primary-fixed-variant text-on-primary font-title-md text-title-md rounded-lg shadow-md shadow-primary/20 transition-all active:scale-[0.98]">
                    <span class="material-symbols-outlined">save</span> Guardar
                </button>
                <a asp-controller="Usuario" asp-action="Lista" class="inline-flex items-center gap-sm h-11 px-md bg-surface-container-high text-on-surface font-title-md text-title-md rounded-lg transition-all hover:bg-surface-container-highest">
                    <span class="material-symbols-outlined">arrow_back</span> Volver
                </a>
            </div>
        </form>
    </div>
</div>